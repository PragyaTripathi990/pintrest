# Backend configuration — copy to .env and adjust as needed
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=43200
DATABASE_URL=sqlite:///./data/pinterest.db
BASE_URL=http://localhost:8000
FRONTEND_ORIGIN=http://localhost:3000

# Optional: a free Pexels API key (https://www.pexels.com/api/) makes generated
# images TOPICAL on search & topic pages (e.g. "dress" -> real fashion photos).
# Leave blank to use keyless Lorem Picsum everywhere.
PEXELS_API_KEY=
